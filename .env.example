# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8084
SERVER_HTTPS=false
SERVER_CERT_PATH=/path/to/cert.pem
SERVER_KEY_PATH=/path/to/key.pem
FRONTEND_URL=http://localhost:3000

# 数据库配置
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=cert_manager
DB_PATH=./cert-manager.db

# 证书配置
CERT_STORE_PATH=./certs
CERT_RENEW_DAYS=30

# 脚本配置
SCRIPT_PATH=/path/to/cert-script.sh
CONFIG_INI_PATH=/path/to/config.ini

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs
