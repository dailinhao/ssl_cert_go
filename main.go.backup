package main

import (
	"fmt"
	"log"

	"cert-manager/backend/api"
	"cert-manager/backend/config"
	"cert-manager/backend/scheduler"
	"cert-manager/backend/store"
)

func main() {
	// 初始化配置管理器
	cm := config.NewConfigManager()

	// 初始化证书存储
	certStore := store.NewCertStore("certs")

	// 初始化续期调度器
	scheduler := scheduler.NewRenewScheduler(cm, certStore)

	// 设置路由
	router := api.SetupRouter(cm, scheduler, certStore)

	// 启动服务器
	port := 8093
	fmt.Printf("Server running on port %d\n", port)
	if err := router.Run(fmt.Sprintf("0.0.0.0:%d", port)); err != nil {
		log.Fatalf("Failed to start server: %v", err)
	}
}
